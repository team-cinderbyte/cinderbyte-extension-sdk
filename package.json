{
  "name": "cinderbyte-ext-sdk",
  "version": "1.0.4",
  "description": "SDK and CLI for building Cinderbyte extensions",
  "type": "module",
  "main": "./runtime/api.js",
  "types": "./runtime/types.d.ts",
  "bin": {
    "cbe": "cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./runtime/api.js",
      "types": "./runtime/types.d.ts"
    },
    "./api": {
      "import": "./runtime/api.js"
    },
    "./types": {
      "types": "./runtime/types.d.ts"
    },
    "./validator": {
      "import": "./validator/manifest.js"
    }
  },
  "files": [
    "cli",
    "core",
    "runtime",
    "validator",
    "utils",
    "templates"
  ],
  "scripts": {
    "dev": "node cli/index.js"
  },
  "keywords": [
    "cinderbyte",
    "extensions",
    "sdk",
    "cli",
    "plugin-system"
  ],
  "license": "MIT",
  "dependencies": {
    "archiver": "^6.0.0",
    "esbuild": "^0.20.0"
  },
  "engines": {
    "node": ">=18"
  }
}
